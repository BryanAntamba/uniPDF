# Configuración del Backend
# Copia este archivo a .env y ajusta la IP según tu red local

# URL del backend (incluye http:// y el puerto)
EXPO_PUBLIC_API_URL=http://192.168.1.100:3000

# Ejemplos:
# Red local: http://192.168.1.100:3000
# Localhost: http://localhost:3000
# Producción: https://api.unipdf.com
